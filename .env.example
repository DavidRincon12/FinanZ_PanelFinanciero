# ============================================================
# FinanZ – Variables de Entorno
# COPIA este archivo a .env y rellena los valores reales.
# NUNCA subas .env a Git.
# ============================================================

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos
# Desarrollo: SQLite
DATABASE_URL=sqlite:///db.sqlite3
# Producción (Neon): descomenta y reemplaza con tu URL real
# DATABASE_URL=postgresql://usuario:contraseña@host.neon.tech/finanz?sslmode=require

# Email (Brevo SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=FinanZ <noreply@finanz.app>
