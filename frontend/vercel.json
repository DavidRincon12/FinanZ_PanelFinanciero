{
  "rewrites": [
    { "source": "/api/:path*",     "destination": "https://finanz-backend.onrender.com/api/:path*" },
    { "source": "/finance/:path*", "destination": "https://finanz-backend.onrender.com/finance/:path*" },
    { "source": "/budget/:path*",  "destination": "https://finanz-backend.onrender.com/budget/:path*" },
    { "source": "/goals/:path*",   "destination": "https://finanz-backend.onrender.com/goals/:path*" },
    { "source": "/admin/:path*",   "destination": "https://finanz-backend.onrender.com/admin/:path*" },
    { "source": "/health/:path*",  "destination": "https://finanz-backend.onrender.com/health/:path*" },
    { "source": "/static/:path*",  "destination": "https://finanz-backend.onrender.com/static/:path*" },
    { "source": "/media/:path*",   "destination": "https://finanz-backend.onrender.com/media/:path*" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
