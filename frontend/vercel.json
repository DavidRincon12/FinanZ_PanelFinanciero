{
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)",     "destination": "https://finanz-backend.onrender.com/api/$1" },
    { "source": "/finance/(.*)", "destination": "https://finanz-backend.onrender.com/finance/$1" },
    { "source": "/budget/(.*)",  "destination": "https://finanz-backend.onrender.com/budget/$1" },
    { "source": "/goals/(.*)",   "destination": "https://finanz-backend.onrender.com/goals/$1" },
    { "source": "/admin/(.*)",   "destination": "https://finanz-backend.onrender.com/admin/$1" },
    { "source": "/health/(.*)",  "destination": "https://finanz-backend.onrender.com/health/$1" },
    { "source": "/static/(.*)",  "destination": "https://finanz-backend.onrender.com/static/$1" },
    { "source": "/media/(.*)",   "destination": "https://finanz-backend.onrender.com/media/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
